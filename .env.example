# Settle — environment variables (devnet defaults)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local at repo root for shared use.
# Each app (apps/web, apps/api, apps/indexer, apps/demo-agent, apps/demo-merchants)
# can also have its own .env.local; values here are the canonical reference.
#
# When migrating to mainnet, see MAINNET_MIGRATION.md for every var that changes.
# ─────────────────────────────────────────────────────────────────────────────

# ── Solana cluster ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Public site URL for canonical hashing + cNFT metadata URIs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# RPC URL — Helius preferred. The NEXT_PUBLIC_ variant exposes the API key in the
# browser bundle (acceptable on devnet; **MUST be removed before mainnet** — use
# server-only RPC_URL for that).
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=                     # server-only Helius key (preferred for mainnet)

# ── Settle Anchor program ─────────────────────────────────────────────────────
# After running `pnpm deploy:devnet` the script prints the program ID; paste it here.
NEXT_PUBLIC_SETTLE_PROGRAM_ID=
SETTLE_AGENT_CARD_PROGRAM_ID=

# Facilitator authority — controls AgentCards created during devnet sandbox.
# 64-byte Ed25519 secret, base58 encoded. Generate via: solana-keygen new -o keys/facilitator.json
# Then: cat keys/facilitator.json | python -c "import json, base58, sys; print(base58.b58encode(bytes(json.loads(sys.stdin.read()))).decode())"
SETTLE_FACILITATOR_PRIVKEY=

# Set to "0" to skip strict envelope authority_sig verification (sandbox testing only).
# Default (any non-"0" value or unset) = strict mode.
SETTLE_STRICT_AUTHORITY_SIG=

# ── USDC mints ───────────────────────────────────────────────────────────────
# Devnet USDC (Circle's devnet test mint — read-only reference)
NEXT_PUBLIC_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC (used Day 11 only for the proof tx)
NEXT_PUBLIC_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Sandbox test-USDC mint (devnet only) ─────────────────────────────────────
# We run our own SPL mint on devnet so /api/sandbox/airdrop can give every user $25 instantly.
# Generate via: spl-token create-token --decimals 6 --url devnet
# Then save the mint address + the authority keypair (base58 64-byte secret).
SETTLE_TEST_USDC_MINT=
SETTLE_TEST_USDC_MINT_AUTHORITY_KEYPAIR_B58=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Pro tier recommended for mainnet. Free tier auto-pauses after 7d inactivity (UptimeRobot ping prevents this on devnet).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # bypasses RLS — server-only, never expose to browser

# Alias used by indexer + scripts:
SUPABASE_URL=

# ── Privy (alt auth — Phantom is primary) ────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Upstash Redis (nonce store + rate limiting) ──────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── libsodium / encryption ───────────────────────────────────────────────────
# 32-byte X25519 keypair (base64). Generate via: pnpm tsx scripts/seal-keygen.ts
SETTLE_SEALED_BOX_PUBKEY=
SETTLE_SEALED_BOX_PRIVKEY=

# ── Demo merchants (devnet pubkeys) ──────────────────────────────────────────
# Generate via solana-keygen for each + on-ramp 0.001 SOL to each
NEXT_PUBLIC_MERCHANT_ARXIV=
NEXT_PUBLIC_MERCHANT_TRANSLATE=
NEXT_PUBLIC_MERCHANT_SUMMARY=
NEXT_PUBLIC_MERCHANT_SARAH=
NEXT_PUBLIC_MERCHANT_AKIRA=

# Server-side merchant pubkey lookup used by /api/x402/proxy/[merchant]
# (route reads MERCHANT_PUBKEY_<UPPER_SLUG>)
MERCHANT_PUBKEY_ARXIV_FETCH=
MERCHANT_PUBKEY_TRANSLATE=
MERCHANT_PUBKEY_SUMMARIZE=
MERCHANT_PUBKEY_SARAH=
MERCHANT_PUBKEY_AKIRA=

# Demo merchants HTTP base URL — used by x402 proxy to forward signed requests
DEMO_MERCHANTS_URL=http://localhost:8788

# ── Demo agent ───────────────────────────────────────────────────────────────
# Used by apps/demo-agent — exported from the user's "Hire AI" flow on /agents
SETTLE_CREDENTIAL=                  # settle://... base64url envelope
SETTLE_AGENT_PRIVKEY=                # base58 64-byte Ed25519 secret for the agent
SETTLE_FACILITATOR_URL=http://localhost:3000  # the apps/web facilitator (this app)

# ── cNFT receipts (Bubblegum V1) ─────────────────────────────────────────────
# Created by `pnpm cnft:setup` once. Tree depth 20 + canopy 13 ≈ 1M cNFTs at ~8.5 SOL one-time.
SETTLE_CNFT_TREE_PUBKEY=
SETTLE_CNFT_COLLECTION_PUBKEY=
SETTLE_TREE_AUTHORITY_KEYPAIR_B58=  # base58 64-byte Ed25519 secret

# ── Indexer ──────────────────────────────────────────────────────────────────
SETTLE_PROGRAM_ID=                  # alias of NEXT_PUBLIC_SETTLE_PROGRAM_ID
SETTLE_CLUSTER=devnet               # devnet | mainnet

# ── Webhook signing ──────────────────────────────────────────────────────────
# HMAC-SHA256 secret used by the indexer's webhook worker to sign outbound webhooks.
# Merchants verify by recomputing HMAC over body + comparing X-Settle-Signature header.
SETTLE_WEBHOOK_SIGNING_SECRET=

# Per-merchant webhook URLs — looked up by first-8-chars-uppercase of pubkey.
# Example: MERCHANT_WEBHOOK_URL_ARXV1111=https://merchant.example/webhook

# ── Lighthouse pre-tx assertions ─────────────────────────────────────────────
# Enable atomic post-tx assertions on the spend tx (defense-in-depth).
# Off on devnet; flip to "1" on mainnet once @lighthouse-web3/sdk is wired.
SETTLE_ENABLE_LIGHTHOUSE=

# ── Production safety toggles ────────────────────────────────────────────────
# Force client-signed envelopes — disables server-signed sandbox mode on mainnet.
SETTLE_REQUIRE_CLIENT_SIGNED_ENVELOPES=

# ── Solana Attestation Service (verified merchants on-chain) ─────────────────
# Operator publishes a "VerifiedSettleMerchant" schema once, then attests each merchant.
# When unset, /api/x402/proxy falls back to Supabase `verified_merchants` for trust.
SAS_PROGRAM_ID=                        # default: AttQEXNJfEmccuWXwt2qfHfPYGcwHSmNa1nuZjhDSXxd
SETTLE_SAS_ATTESTOR_PUBKEY=             # the operator pubkey that issues attestations
SETTLE_SAS_MERCHANT_SCHEMA_PDA=         # the schema PDA for "VerifiedSettleMerchant"
# Set to "1" to fail-open if SAS RPC errors (lenient); else fail-closed (strict)
SETTLE_SAS_FAIL_OPEN=

# ── Optional integrations (Day 13+) ──────────────────────────────────────────
# Anthropic API key for the live demo agent — not required for devnet test runs
ANTHROPIC_API_KEY=

# OpenAI API key — alternate LLM for the demo agent
OPENAI_API_KEY=
