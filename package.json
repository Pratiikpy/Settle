{
  "name": "settle-protocol",
  "private": true,
  "version": "0.2.0",
  "description": "Settle — Pay anyone. Hire any AI. Trust the receipts.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @settle/web dev",
    "dev:merchants": "pnpm --filter @settle/demo-merchants dev",
    "dev:agent": "pnpm --filter @settle/demo-agent dev",
    "dev:indexer": "pnpm --filter @settle/indexer dev",
    "dev:all": "concurrently -k -n web,merchants,indexer -c green,yellow,magenta \"pnpm dev:web\" \"pnpm dev:merchants\" \"pnpm dev:indexer\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:sdk": "pnpm --filter @settle/sdk test",
    "anchor:build": "bash scripts/deploy-devnet.sh",
    "anchor:test": "cd programs/settle-agent-card && anchor test",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "seed:supabase": "tsx scripts/seed-supabase.ts",
    "seed:demo-card": "tsx scripts/seed-demo-card.ts",
    "cnft:setup": "tsx scripts/cnft-setup.ts",
    "vapid:keygen": "tsx scripts/vapid-keygen.ts",
    "seal:keygen": "tsx scripts/seal-keygen.ts",
    "badge:keygen": "tsx scripts/badge-keygen.ts",
    "verify:idl": "tsx scripts/verify-idl.ts",
    "codegen": "turbo run codegen",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@metaplex-foundation/mpl-bubblegum": "^4.4.0",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@types/node": "^22.7.5",
    "bs58": "^6.0.0",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.12.0"
  }
}
