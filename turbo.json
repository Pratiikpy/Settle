{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "SETTLE_AGENT_CARD_PROGRAM_ID",
    "SETTLE_PROGRAM_ID",
    "SETTLE_CLUSTER",
    "SETTLE_DEPLOYER_PUBKEY",
    "SETTLE_FACILITATOR_PUBKEY",
    "SETTLE_FACILITATOR_PRIVKEY",
    "SETTLE_BADGE_AUTHORITY_PUBKEY",
    "SETTLE_BADGE_AUTHORITY_PRIVKEY",
    "SETTLE_ZK_RECEIPT_AUTHORITY_PUBKEY",
    "SETTLE_ZK_RECEIPT_AUTHORITY_PRIVKEY",
    "SETTLE_ZK_RECEIPT_MINT",
    "SETTLE_VAPID_PUBLIC_KEY",
    "SETTLE_VAPID_PRIVATE_KEY",
    "SETTLE_VAPID_SUBJECT",
    "SETTLE_SEALED_BOX_PUBKEY",
    "SETTLE_SEALED_BOX_PRIVKEY",
    "SETTLE_WEBHOOK_SECRET",
    "SETTLE_INTERNAL_API_KEY",
    "SETTLE_WEB_BASE",
    "SETTLE_ESCROW_CRON_PRIVKEY",
    "SETTLE_RELAYER_LIVE",
    "SETTLE_RELAYER_PRIVKEY",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_ACCESS_TOKEN",
    "SUPABASE_PROJECT_REF",
    "HELIUS_API_KEY",
    "CRON_SECRET",
    "NVIDIA_NIM_API_KEY",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "PRIVY_APP_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SOLANA_CLUSTER",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_RPC_URL",
        "NEXT_PUBLIC_SETTLE_PROGRAM_ID",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "NEXT_PUBLIC_USDC_MINT_DEVNET",
        "NEXT_PUBLIC_USDC_MINT_MAINNET",
        "NEXT_PUBLIC_MERCHANT_ARXIV",
        "NEXT_PUBLIC_MERCHANT_TRANSLATE",
        "NEXT_PUBLIC_MERCHANT_SUMMARY",
        "NEXT_PUBLIC_MERCHANT_SARAH",
        "NEXT_PUBLIC_MERCHANT_AKIRA",
        "NEXT_PUBLIC_PRIVY_APP_ID"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "codegen": {
      "outputs": ["src/generated/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
