{
  "name": "@settle-web/web-components",
  "version": "0.1.1",
  "description": "Vanilla web components for Settle: <settle-pay> + <settle-verify>.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pay": {
      "types": "./dist/pay.d.ts",
      "import": "./dist/pay.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "echo 'covered by E2E in Wave 4'"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiikpy/Settle.git",
    "directory": "packages/web-components"
  },
  "homepage": "https://github.com/Pratiikpy/Settle/tree/main/packages/web-components#readme",
  "bugs": {
    "url": "https://github.com/Pratiikpy/Settle/issues"
  }
}
