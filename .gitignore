# Whitelist Anchor's generated IDL JSON so the Codama drift-detector
# (scripts/verify-idl.ts) can compare it against the hand-maintained idl.ts.
# Pattern: re-ignore everything under target/ except idl/*.json specifically.
!programs/settle-agent-card/target/
programs/settle-agent-card/target/*
!programs/settle-agent-card/target/idl/
programs/settle-agent-card/target/idl/*
!programs/settle-agent-card/target/idl/*.json

# Track build-info.json so /api/verify-build can claim a sha256 to compare
# against the on-chain bytecode. Required for matches=true.
!programs/settle-agent-card/target/deploy/
programs/settle-agent-card/target/deploy/*
!programs/settle-agent-card/target/deploy/build-info.json

