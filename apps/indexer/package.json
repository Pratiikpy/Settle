{
  "name": "@settle/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Helius LaserStream subscriber that watches PolicyDecisionEvent emissions on the Settle program and writes to Supabase. Powers the live activity feed.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "dev:escrow-cron": "tsx watch src/escrow-cron.ts",
    "start:escrow-cron": "tsx src/escrow-cron.ts",
    "dev:badge-cron": "tsx watch src/badge-cron.ts",
    "start:badge-cron": "tsx src/badge-cron.ts",
    "dev:compress-cron": "tsx watch src/compress-cron.ts",
    "start:compress-cron": "tsx src/compress-cron.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@lightprotocol/compressed-token": "^0.23.3",
    "@lightprotocol/stateless.js": "^0.23.3",
    "@metaplex-foundation/mpl-core": "^1.1.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@noble/hashes": "^1.5.0",
    "@settle/sdk": "workspace:*",
    "@settle/types": "workspace:*",
    "@solana/web3.js": "^1.95.5",
    "@supabase/supabase-js": "^2.45.4",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
